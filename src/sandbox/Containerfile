# Sandbox worker container.
# See isolation/ for security primitives (bwrap, seccomp).

FROM oven/bun:1-alpine AS builder

# Install build dependencies
RUN apk add --no-cache gcc musl-dev libseccomp-dev libseccomp-static linux-headers

# Copy and build seccomp tools
COPY sandbox/isolation/seccomp/ /build/
WORKDIR /build

# Build the BPF filter generator and generate the filter
# Detect architecture: map to x64/arm64 for seccomp-net-block
RUN gcc -o seccomp-net-block seccomp-net-block.c -lseccomp \
    && ARCH=$(uname -m) \
    && if [ "$ARCH" = "x86_64" ]; then ARCH="x64"; elif [ "$ARCH" = "aarch64" ]; then ARCH="arm64"; fi \
    && ./seccomp-net-block "$ARCH" /build/net-block.bpf

# --- Runtime stage ---
FROM oven/bun:1-alpine

RUN apk add --no-cache \
    git \
    ripgrep \
    fd \
    coreutils \
    bubblewrap \
    bash \
    libcap \
    libseccomp \
    && adduser -D -h /home/forge forge \
    && mkdir -p /home/forge/repos \
    && chown -R forge:forge /home/forge

# Copy seccomp BPF filter from builder (arch-specific path expected by worker.ts)
COPY --from=builder /build/net-block.bpf /tmp/net-block.bpf
RUN ARCH=$(uname -m) \
    && if [ "$ARCH" = "x86_64" ]; then ARCH="x64"; elif [ "$ARCH" = "aarch64" ]; then ARCH="arm64"; fi \
    && mkdir -p /etc/seccomp/$ARCH \
    && mv /tmp/net-block.bpf /etc/seccomp/$ARCH/net-block.bpf

# Copy application files — layout must match import paths:
#   worker.ts imports "../tool-commands" → /app/tool-commands.ts
#   worker.ts imports "./isolation"      → /app/sandbox/isolation/index.ts
#   tool-commands.ts imports "./tools"   → /app/tools.ts (for TypeBox-backed arg validation)
COPY sandbox/worker.ts /app/sandbox/worker.ts
COPY sandbox/isolation/index.ts /app/sandbox/isolation/index.ts
COPY tool-commands.ts /app/tool-commands.ts
COPY tools.ts /app/tools.ts

# Install the TypeBox runtime used by tools.ts for argument validation.
# pi-ai is imported type-only in tools.ts, so it doesn't need to be installed.
WORKDIR /app
RUN bun add @sinclair/typebox@0.34.49

USER forge
WORKDIR /home/forge

EXPOSE 8080

# Clear ambient capabilities before starting the worker.
# Apple Container gives non-root users full ambient caps (CapAmb: ffffffff),
# unlike Docker with runc/gVisor which clears them. This causes bwrap to
# refuse to run with: "Unexpected capabilities but not setuid, old file caps
# config?"
# capsh --inh= clears inheritable+ambient caps so bwrap uses unprivileged
# user namespaces instead. On runtimes that don't set ambient caps, this is
# a no-op.
CMD ["capsh", "--shell=/usr/local/bin/bun", "--inh=", "--", "run", "/app/sandbox/worker.ts"]
